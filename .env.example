# PostgreSQL
POSTGRES_DB=inspections_db
POSTGRES_USER=inspections_user
POSTGRES_PASSWORD=inspections_pass
DATABASE_URL=postgresql+asyncpg://inspections_user:inspections_pass@postgres:5432/inspections_db

# Redis
REDIS_URL=redis://redis:6379/0

# MinIO (S3-compatible)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin123
S3_BUCKET=evidences
EVIDENCE_MAX_FILE_SIZE_BYTES=10485760
EVIDENCE_ALLOWED_MIME_TYPES=image/jpeg,image/png,image/webp,application/pdf

# Auth
JWT_SECRET=change-me-in-production-use-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# App
APP_ENV=development
LOG_LEVEL=INFO
